type TimeTracking {
  id: ID!
  characterID: ID!
  metricID: ID
  startTime: String!
  endTime: String
}

type Query {
  currentTimeTracking(characterID: ID!): TimeTracking
}

type Mutation {
  createTimeTracking(
    characterID: ID!
    metricID: ID
    """
    Start time of the tracking session in RFC3339 format.
    """
    startTime: String!
  ): TimeTracking!

  updateTimeTracking(id: ID!): TimeTracking!
}
