type Query {
  characters: [Character!]!
  profile: Profile!
  appSettings: AppSettings!
  goals(characterID: ObjectID!, status: GoalStatusFilter): [Goal!]!
}

type Mutation {
  updateProfile(input: ProfileInput!): Profile!
  deleteProfile: Profile!

  upsertCharacter(input: CharacterInput!): Character!
  deleteCharacter(id: ObjectID!): Character!

  upsertGoal(characterID: ObjectID!, input: GoalInput!): Goal!
}
