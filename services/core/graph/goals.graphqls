type Goal {
  ID: ObjectID!
  CreatedAt: Time!
  UpdatedAt: Time!
  CharacterID: ObjectID!
  Name: String!
  Description: String!
  StartDate: Time!
  EndDate: Time!
  Status: GoalStatus!
  Target: [CustomMetric!]
}

enum GoalStatus {
  Active
  Finished
  Expired
}

input GoalInput {
  Name: String
  Description: String
  StartDate: Time
  EndDate: Time
  Target: [CustomMetricInput!]
}