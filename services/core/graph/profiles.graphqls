scalar Time
scalar ObjectID
scalar NullableString

directive @goTag(key: String!, value: String) on INPUT_FIELD_DEFINITION | FIELD_DEFINITION

type Profile {
  id: ObjectID!
  name: String!
  email: String!
  firebaseUID: String!
  imageURL: String!
  currentCharacterID: ObjectID
  characters: [Character!]!
  availableSnapshots: Int!
  autoSnapshot: Boolean!
  createdAt: Time!
  updatedAt: Time!
}

"""
Input type for creating or updating a user profile.
"""
input ProfileInput {
  """
  The name of the user.
  """
  name: String @goTag(key: "validate", value: "required,min=1,max=50")

  """
  URL of the user's image.
  """
  imageURL: String

  """
  ID of the character currently being chosen by the user.
  """
  currentCharacterID: ObjectID

  """
  Whether the user has enabled auto snapshot, default is true
  """
  autoSnapshot: Boolean
}
