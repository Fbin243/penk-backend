type Mutation {
  createSnapshot(characterID: ObjectID!, description: String): Snapshot!
  createCapturedRecord(characterID: ObjectID!): CapturedRecord!
}

type Query {
  snapshots(characterID: ObjectID, filter: Filter): [Snapshot!]!
  analyticResults(characterID: ObjectID, filter: Filter): JSON!
}

input Filter {
  month: Month
  year: Int
}

