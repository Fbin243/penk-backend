scalar Time
scalar ObjectID

type TimeTracking {
  id: ObjectID!
  characterID: ObjectID!
  customMetricID: ObjectID
  startTime: Time!
  endTime: Time
}

type Query {
  currentTimeTracking: TimeTracking
}

type Mutation {
  createTimeTracking(
    characterID: ObjectID!
    customMetricID: ObjectID
    """
    Start time of the tracking session in RFC3339Nano format.
    """
    startTime: Time!
  ): TimeTracking!

  updateTimeTracking: TimeTrackingWithFish!
}

type TimeTrackingWithFish {
  timeTracking: TimeTracking!
  normal: Int!
  gold: Int!
}
